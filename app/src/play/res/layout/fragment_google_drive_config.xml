<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pref_drive_enabled_summary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:id="@+id/layout_not_signed_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_drive_sign_in"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_drive_sign_in_title" />

            <ProgressBar
                android:id="@+id/progress_sign_in"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_signed_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/text_signed_in_as"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_create_household"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_drive_create_household_title"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_join_household"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_drive_join_household_title"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btn_drive_sign_out"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign Out"
                android:textColor="#F44336" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
