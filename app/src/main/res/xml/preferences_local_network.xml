<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="@string/pref_cat_local_network"
        android:key="pref_cat_local_network">

        <!-- ENABLE/DISABLE SWITCH -->
        <SwitchPreferenceCompat
            android:title="@string/pref_local_network_enabled_title"
            android:summary="@string/pref_local_network_enabled_summary"
            android:key="sync_local_network_enabled"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <!-- Device Name (shown only when enabled) -->
        <EditTextPreference
            android:title="@string/pref_local_device_name_title"
            android:summary="@string/pref_local_device_name_summary"
            android:key="pref_local_device_name"
            android:hint="My Phone"
            android:inputType="text"
            android:visible="false"
            app:iconSpaceReserved="false" />

        <!-- Scan Button (shown only when enabled) -->
        <Preference
            android:title="@string/pref_local_scan_peers_title"
            android:summary="@string/pref_local_scan_peers_summary"
            android:key="pref_local_scan_peers"
            android:visible="false"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>
